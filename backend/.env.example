# AI-CRM Backend 环境变量模板
# 复制此文件为 .env 后修改

# 方式1: 单行 DSN
# DATABASE_URL=postgresql+psycopg2://postgres:your-password@localhost:5432/ai_crm

# 方式2: 独立变量 (推荐，避免密码特殊字符编码问题)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your-password-here
DB_NAME=ai_crm

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT 密钥 (留空自动生成 secrets.token_urlsafe(64))
# SECRET_KEY=

# AI 模型 API Key
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
