# ===== 数据库 (必填) =====
DATABASE_URL=mysql+pymysql://crm_user:CHANGE_ME@localhost:3306/ai_crm

# ===== 数据库连接池 (可选) =====
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ===== JWT密钥 (必填，生产环境使用强随机字符串) =====
# 开发环境留空则自动生成 (每次重启变化)
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ===== Redis (可选) =====
REDIS_URL=redis://localhost:6379/0

# ===== CORS允许的前端地址 =====
CORS_ORIGINS=["http://localhost:3000","http://192.168.0.169:3000","http://192.168.0.168:3000"]

# ===== 运行环境 (development / staging / production) =====
APP_ENV=development
