{
  "model": "deepseek-v4-pro",
  "autoCompactEnabled": true,
  "autoCompactWindow": 400000,
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(python:*)",
      "Bash(docker:*)",
      "Bash(ssh:*)",
      "Bash(curl:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(shutdown:*)",
      "Write(/etc/*)",
      "Write(/Windows/*)"
    ]
  }
}
